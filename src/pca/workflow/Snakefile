"""Snakemake workflow for phage contig annotation.

The workflow expects ``config.yaml`` in the working directory with at least:

- ``input``: path to input FASTA (contigs or proteins)
- ``input_type``: ``"contigs"`` or ``"proteins"``
- ``output_dir``: top-level output directory
- ``db_dir``: root directory containing database subdirectories
- ``primary_db``: name of the primary database to use (default: ``phrogs``)
- ``meta_path``: path to PHROG metadata TSV (optional; auto-discovered if omitted)
- ``run_trna``: whether to run tRNAscan-SE (default: true)
- ``run_trf``: whether to run Tandem Repeats Finder (default: true)
- ``run_minced``: whether to run MinCED (default: false)
- ``run_multicopy``: whether to run multi-copy detection (default: true)
- ``plot_formats``: list of plot formats, e.g. ``["pdf"]`` or ``["pdf", "html"]``
"""

from pca.databases import discover_databases

input_path = Path(config["input"])
output_dir = Path(config["output_dir"])
input_type = config.get("input_type", "contigs")
gene_caller = config.get("gene_caller", "pyrodigal-gv")
run_trna = config.get("run_trna", True)
run_trf = config.get("run_trf", True) and input_type == "contigs"
db_dir = Path(config["db_dir"])
primary_db_name = config.get("primary_db", "phrogs")

# Discover the primary database bundle.  ``hmms_path`` is the directory used
# by pyhmmer, and ``metadata_path`` is the PHROG metadata used for category
# coloring.
_discovered = discover_databases(str(db_dir))
if primary_db_name not in _discovered:
    raise ValueError(
        f"Primary database '{primary_db_name}' not found under {db_dir}. "
        f"Available databases: {', '.join(sorted(_discovered))}"
    )
_primary_bundle = _discovered[primary_db_name]
if not _primary_bundle.has_hmms:
    raise ValueError(
        f"Primary database '{primary_db_name}' has no HMM profiles in {_primary_bundle.hmms_path}"
    )

hmm_db_dir = _primary_bundle.hmms_path
meta_path = Path(config.get("meta_path", str(_primary_bundle.metadata_path)))
plot_formats = config.get("plot_formats", ["pdf"])
translation_table = config.get("translation_table", None)
theme = config.get("theme", "light")

extra_db_root = config.get("extra_db_root", None)
extra_dbs = config.get("extra_dbs", [])
extra_evalue = config.get("extra_evalue", 1e-5)
run_defensefinder = config.get("run_defensefinder", False)

# DefenseFinder is a separate tool, not an HMM/FASTA database, so exclude it
# from the list of databases used by the extra_hmmsearch rule.
hmm_extra_dbs = [db for db in extra_dbs if db != "defensefinder"]

extra_dir = output_dir / "extra"
defensefinder_dir = output_dir / "defensefinder"
defensefinder_genes_tsv = defensefinder_dir / "defense_finder_genes.tsv"

crisprcasfinder_dir = output_dir / "crisprcasfinder"
crisprcasfinder_gff = crisprcasfinder_dir / "crisprcasfinder.gff"

minced_dir = output_dir / "minced"
minced_gff = minced_dir / "minced.gff"


proteins_faa = output_dir / "genes" / "proteins.faa"
proteins_gff = output_dir / "genes" / "proteins.gff"
genes_per_contig_dir = output_dir / "genes" / "per_contig"

trna_tsv = output_dir / "trna" / "trna.tsv"
trna_gff = output_dir / "trna" / "trna.gff"
trna_per_contig_dir = output_dir / "trna" / "per_contig"

trf_dat = output_dir / "trf" / "trf.dat"
trf_per_contig_dir = output_dir / "trf" / "per_contig"

hmmsearch_txt = output_dir / "hmm" / "hmmsearch.txt"
hmmsearch_csv = output_dir / "hmm" / "hmmsearch.csv"
hmm_per_contig_dir = output_dir / "hmm" / "per_contig"

annotations_gff = output_dir / "annotations" / "annotations.gff"
annotations_gbk = output_dir / "annotations" / "annotations.gbk"
annotations_per_contig_dir = output_dir / "annotations" / "per_contig"
plots_dir = output_dir / "plots"
plot_done_files = [plots_dir / f".{fmt}_done" for fmt in plot_formats]

stats_dir = output_dir / "stats"
stats_tsv = stats_dir / "stats.tsv"


run_crisprcasfinder = config.get("run_crisprcasfinder", False)
run_minced = config.get("run_minced", False)
run_multicopy = config.get("run_multicopy", True)

multicopy_dir = output_dir / "multicopy"
multicopy_tsv = multicopy_dir / "multicopy.tsv"


def _extra_db_path(db):
    """Resolve the path for an optional extra database."""
    root = Path(extra_db_root) if extra_db_root else db_dir / "extra"
    return root / db


rule all:
    """Final outputs: per-contig files, combined annotation files, and stats."""
    input:
        gff=annotations_gff,
        gbk=annotations_gbk,
        genes_per_contig=genes_per_contig_dir,
        hmm_per_contig=hmm_per_contig_dir,
        trna_per_contig=trna_per_contig_dir,
        trf_per_contig=trf_per_contig_dir,
        annotations_per_contig=annotations_per_contig_dir,
        plots=plot_done_files,
        stats=stats_tsv if input_type == "contigs" else [],
        crisprcasfinder=crisprcasfinder_dir if run_crisprcasfinder else [],
        minced=minced_dir if run_minced else [],
        multicopy=multicopy_dir if run_multicopy else [],


if input_type == "contigs":

    rule gene_calling:
        """Predict genes with the selected gene caller."""
        input:
            fna=input_path,
        output:
            faa=proteins_faa,
            gff=proteins_gff,
        threads: workflow.cores
        run:
            if gene_caller == "phanotate":
                from pca.pipeline import call_genes_phanotate

                call_genes_phanotate(
                    input.fna,
                    output.faa,
                    output.gff,
                    threads=threads,
                )
            else:
                from pca.pipeline import call_genes_pyrodigal

                call_genes_pyrodigal(
                    input.fna,
                    output.faa,
                    output.gff,
                    threads=threads,
                    translation_table=translation_table,
                )

else:

    rule stage_proteins:
        """Copy a user-supplied protein FASTA into the output directory."""
        input:
            faa=input_path,
        output:
            faa=proteins_faa,
        run:
            import shutil

            shutil.copy(input.faa, output.faa)


rule split_genes:
    """Split combined gene outputs into per-contig files."""
    input:
        faa=proteins_faa,
        gff=proteins_gff,
    output:
        directory(genes_per_contig_dir),
    run:
        from pca.io import split_fasta_by_contig, split_gff_by_contig

        split_fasta_by_contig(input.faa, output[0], filename="proteins.faa")
        split_gff_by_contig(input.gff, output[0], filename="proteins.gff")


if run_trf:

    rule trf_calling:
        """Predict tandem repeat regions with TRF."""
        input:
            fna=input_path,
        output:
            dat=trf_dat,
        threads: workflow.cores
        run:
            from pca.externals import run_trf

            run_trf(
                out=str(output_dir / "trf" / "trf"),
                in_=str(input.fna),
                threads=threads,
                flags=["-f", "-d", "-m"],
            )

else:

    rule empty_trf:
        """Create an empty TRF dat file when repeat finding is disabled."""
        output:
            dat=trf_dat,
        run:
            with open(output.dat, "w") as fh:
                fh.write("")


rule split_trf:
    """Split combined TRF output into per-contig files."""
    input:
        dat=trf_dat,
    output:
        directory(trf_per_contig_dir),
    run:
        from pca.io import split_trf_dat_by_contig

        split_trf_dat_by_contig(input.dat, output[0], filename="trf.dat")


if run_trna:

    rule trna_calling:
        """Predict tRNAs with tRNAscan-SE."""
        input:
            fna=input_path,
        output:
            tsv=trna_tsv,
            gff=trna_gff,
        threads: workflow.cores
        run:
            from pca.externals import run_trnascan

            run_trnascan(
                out=str(output_dir / "trna" / "trna"),
                in_=str(input.fna),
                threads=threads,
            )

else:

    rule empty_trna:
        """Create an empty tRNA GFF when tRNA scanning is disabled."""
        output:
            tsv=trna_tsv,
            gff=trna_gff,
        run:
            with open(output.tsv, "w") as fh:
                fh.write("")
            with open(output.gff, "w") as fh:
                fh.write("##gff-version 3\n")


rule split_trna:
    """Split combined tRNA outputs into per-contig files."""
    input:
        tsv=trna_tsv,
        gff=trna_gff,
    output:
        directory(trna_per_contig_dir),
    run:
        from pca.io import split_gff_by_contig, split_trna_tsv_by_contig

        split_trna_tsv_by_contig(input.tsv, output[0], filename="trna.tsv")
        split_gff_by_contig(input.gff, output[0], filename="trna.gff")


rule hmmsearch:
    """Search predicted proteins against HMM databases with pyhmmer."""
    input:
        faa=proteins_faa,
    output:
        txt=hmmsearch_txt,
        csv=hmmsearch_csv,
    threads: workflow.cores
    params:
        db_dir=hmm_db_dir,
    run:
        from pca.pipeline import search_hmms_pyhmmer

        search_hmms_pyhmmer(
            input.faa,
            params.db_dir,
            output.txt,
            output.csv,
            threads=threads,
        )


rule split_hmm:
    """Split combined HMM search output into per-contig files."""
    input:
        txt=hmmsearch_txt,
        csv=hmmsearch_csv,
    output:
        directory(hmm_per_contig_dir),
    run:
        from pca.io import split_csv_by_contig, split_hmmsearch_by_contig

        split_hmmsearch_by_contig(input.txt, output[0], filename="hmmsearch.txt")
        split_csv_by_contig(
            input.csv, output[0], filename="hmmsearch.csv", contig_column="qname"
        )


rule extra_hmmsearch:
    """Search proteins against an optional extra HMM/protein database."""
    input:
        faa=proteins_faa,
    output:
        txt=extra_dir / "{db}.txt",
        csv=extra_dir / "{db}.csv",
    threads: workflow.cores
    params:
        db_path=lambda wc: _extra_db_path(wc.db),
        evalue=extra_evalue,
    run:
        from pca.pipeline import search_extra_db

        search_extra_db(
            input.faa,
            params.db_path,
            output.txt,
            output.csv,
            threads=threads,
            evalue=params.evalue,
        )


if run_defensefinder:

    rule defensefinder:
        """Detect anti-phage defense systems with DefenseFinder."""
        input:
            faa=proteins_faa,
        output:
            genes=defensefinder_genes_tsv,
        threads: workflow.cores
        run:
            from pca.externals import run_defensefinder

            run_defensefinder(
                out=str(defensefinder_dir),
                in_=str(input.faa),
                threads=threads,
            )


rule annotate:
    """Generate annotated GFF/GenBank and per-contig plots."""
    input:
        hmmsearch=hmmsearch_txt,
        trna_gff=trna_gff,
        trf_dat=trf_dat,
        proteins_gff=proteins_gff if input_type == "contigs" else [],
        meta=meta_path,
        extra_csvs=expand(str(extra_dir / "{db}.csv"), db=hmm_extra_dbs) if hmm_extra_dbs else [],
        defensefinder_tsv=str(defensefinder_genes_tsv) if run_defensefinder else [],
        minced_gff=str(minced_gff) if run_minced else [],
        stats=stats_tsv if input_type == "contigs" else [],
    output:
        gff=annotations_gff,
        gbk=annotations_gbk,
        per_contig=directory(annotations_per_contig_dir),
        done=plot_done_files,
    run:
        from pca.annotations import generate_plots_and_annotations

        gff_input = input.proteins_gff if input_type == "contigs" else str(proteins_gff)
        extra_hits = {
            db: str(extra_dir / f"{db}.csv")
            for db in hmm_extra_dbs
        }
        defensefinder_input = input.defensefinder_tsv if isinstance(input.defensefinder_tsv, str) else None
        minced_input = input.minced_gff if isinstance(input.minced_gff, str) else None
        stats_input = input.stats if isinstance(input.stats, str) else None

        generate_plots_and_annotations(
            tmp_dir=output_dir,
            hmmsearch_dir=input.hmmsearch,
            trna_dir=input.trna_gff,
            trf_path=input.trf_dat,
            meta_dir=input.meta,
            gff_dir=gff_input,
            input_fasta=input_path,
            plot_formats=plot_formats,
            translation_table=translation_table,
            theme=theme,
            extra_hits=extra_hits or None,
            defensefinder_tsv=defensefinder_input,
            minced_gff=minced_input,
            stats_tsv=stats_input,
        )


rule genome_stats:
    """Compute per-contig genomic statistics (strand switching, repeats, CRISPR arrays, copy number)."""
    input:
        fna=input_path,
        gff=proteins_gff,
        trf=trf_dat,
        crispr=crisprcasfinder_gff if run_crisprcasfinder else [],
        minced=minced_gff if run_minced else [],
        multicopy=multicopy_tsv if run_multicopy else [],
    output:
        tsv=stats_tsv,
    run:
        from pca.genome_stats import compute_genome_stats

        df = compute_genome_stats(
            input.fna,
            input.gff,
            trf_path=input.trf if run_trf else None,
            crispr_path=input.crispr if run_crisprcasfinder else None,
            minced_path=input.minced if run_minced else None,
            multicopy_path=input.multicopy if run_multicopy else None,
        )
        stats_dir.mkdir(parents=True, exist_ok=True)
        df.to_csv(output.tsv, sep="\t", index=False)


if run_crisprcasfinder:

    rule crispr_cas_finder:
        """Detect CRISPR arrays and Cas genes with CRISPRCasFinder."""
        input:
            fna=input_path,
        output:
            outdir=directory(crisprcasfinder_dir),
            gff=crisprcasfinder_gff,
        threads: workflow.cores
        run:
            from pca.externals import run_crispr_cas_finder

            run_crispr_cas_finder(
                out=str(crisprcasfinder_dir),
                in_=str(input.fna),
                threads=threads,
            )


if run_minced:

    rule minced:
        """Detect CRISPR arrays with MinCED."""
        input:
            fna=input_path,
        output:
            outdir=directory(minced_dir),
            gff=minced_gff,
        run:
            from pca.externals import run_minced

            run_minced(
                out=str(minced_dir / "minced"),
                in_=str(input.fna),
            )


if run_multicopy:

    rule multicopy:
        """Detect multi-copy viral contigs using k-mer frequency and FFT."""
        input:
            fna=input_path,
        output:
            outdir=directory(multicopy_dir),
            tsv=multicopy_tsv,
        run:
            from pca.multicopy import detect_multicopy

            multicopy_dir.mkdir(parents=True, exist_ok=True)
            df = detect_multicopy(str(input.fna))
            df.to_csv(str(output.tsv), sep="\t", index=False)
